# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ========================
# DEPENDENCIES
# ========================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
jspm_packages/
bower_components/

# ========================
# NEXT.JS BUILD OUTPUT
# ========================
/.next/
/out/
/build
dist/
.output

# ========================
# ENVIRONMENT & SECRETS
# ========================
.env
.env.*
!.env.example
!.env.local.example
!.env.template
*.pem
*.key
*.crt
*.p12
*.pfx

# ========================
# SECURITY PATCHES & BACKUPS
# ========================
.security-backups/
*.backup
*.bak
*.orig
*.swp
*.swo
*~
fix-security.sh

# ========================
# LOGS & DEBUG
# ========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log
logs/
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ========================
# TESTING
# ========================
/coverage
*.lcov
.nyc_output

# ========================
# CACHE
# =================-------
.eslintcache
.stylelintcache
.cache/
.parcel-cache
*.tsbuildinfo
next-env.d.ts

# ========================
# VERCEL / DEPLOYMENT
